  },
  "keywords": ["bookstore", "ecommerce", "ai", "momo"],
  "author": "BookHub Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "express-mongo-sanitize": "^2.2.0",
    "multer": "^1.4.5-lts.1",
    "cloudinary": "^1.41.3",
    "openai": "^4.24.1",
    "@google/generative-ai": "^0.2.1",
    "nodemailer": "^6.9.7",
    "uuid": "^9.0.0",
    "slugify": "^1.6.6",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "cookie-parser": "^1.4.6",
    "compression": "^1.7.4",
    "xss-clean": "^0.1.4",
    "hpp": "^0.2.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "mongodb-memory-server": "^9.1.6"
  },
  "jest": {
