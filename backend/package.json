{
  "name": "bookhub-backend",
  "version": "1.0.0",
  "description": "BookHub AI-Powered Bookstore Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
